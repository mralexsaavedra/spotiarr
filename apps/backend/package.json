{
  "name": "backend",
  "version": "0.0.0",
  "description": "SpotiArr Backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm prisma:generate && tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "oxlint src --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "@spotiarr/shared": "workspace:*",
    "bullmq": "^5.78.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "music-metadata": "^11.13.0",
    "node-cron": "^4.2.1",
    "node-id3": "^0.2.9",
    "ytdlp-nodejs": "^3.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@spotiarr/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^3.0.0",
    "prisma": "5.22.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "vitest": "^3.0.0"
  }
}
