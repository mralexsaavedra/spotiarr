# ===========================================
# SpotiArr Configuration
# ===========================================

# Spotify API Credentials (REQUIRED)
# Get yours at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# YouTube Settings
# YT_COOKIES: Optional - for age-restricted content (export from browser)
# YT_DLP_PATH: Optional - custom path to yt-dlp binary (auto-detected if not set)
# YT_COOKIES=
YT_DOWNLOADS_PER_MINUTE=3

# Server Configuration
PORT=3000
FORMAT=mp3

# Database
DB_PATH=./config/db.sqlite

# Paths (relative to backend)
FE_PATH=../frontend/browser
DOWNLOADS_PATH=./downloads

# Redis Configuration
# For docker-compose: REDIS_HOST=redis
# For local development: REDIS_HOST=localhost
REDIS_HOST=redis
REDIS_PORT=6379

# M3U Playlist Generation
M3U_GENERATION_ENABLED=true
