{
  "name": "spotiarr",
  "version": "0.1.0",
  "description": "Self-hosted Spotify downloader with Jellyfin/Plex integration. Lidarr-inspired music automation.",
  "keywords": [
    "spotify",
    "downloader",
    "self-hosted",
    "media-server",
    "jellyfin",
    "plex",
    "music",
    "automation",
    "lidarr-alternative"
  ],
  "author": "Alexander Saavedra <mralexsaavedra@gmail.com>",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mralexsaavedra/spotiarr.git"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "concurrently \"pnpm start:be\" \"pnpm start:fe\"",
    "start:be": "pnpm --filter backend run start:dev",
    "start:fe": "pnpm --filter frontend run start",
    "build": "pnpm run build:be && pnpm run build:fe",
    "build:be": "pnpm --filter backend run build",
    "build:fe": "pnpm --filter frontend run build",
    "start": "pnpm --filter backend run start:prod",
    "lint": "pnpm --filter backend lint && pnpm --filter frontend lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2"
  }
}
