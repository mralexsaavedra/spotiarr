{
  "version": "0.1.0",
  "name": "spotiarr",
  "description": "Self-hosted Spotify downloader with media server integration and *ARR compatibility",
  "author": "Alexander Saavedra <mralexsaavedra@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mralexsaavedra/spotiarr.git"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "start:be": "pnpm --filter backend run start:dev",
    "start:fe": "pnpm --filter frontend run start",
    "build:be": "pnpm --filter backend run build",
    "build:fe": "pnpm --filter frontend run build",
    "build": "pnpm run build:be && pnpm run build:fe",
    "gen:fe": "pnpm --filter frontend run gen",
    "gen:be": "pnpm --filter backend run gen",
    "start": "pnpm --filter backend run start:prod",
    "clean": "rimraf dist",
    "changelog": "auto-changelog -p",
    "commit": "cz",
    "check:lib": "pnpm --filter backend update ytdlp-nodejs"
  },
  "devDependencies": {
    "auto-changelog": "^2.5.0",
    "commitizen": "^4.3.1",
    "copy-files-from-to": "^3.2.2",
    "cz-conventional-changelog": "^3.3.0",
    "npm-check-updates": "^17.1.15",
    "rimraf": "^6.0.1"
  }
}
